{
	"name": "obsidigram",
	"version": "0.1.1",
	"packageManager": "pnpm@9.15.0",
	"description": "Turn Obsidian into a headless CMS for Telegram",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json ../manifest.json"
	},
	"keywords": [
		"obsidian",
		"telegram",
		"scheduler",
		"cms"
	],
	"author": "dancingteeth",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/dancingteeth/obsidigram.git"
	},
	"homepage": "https://github.com/dancingteeth/obsidigram#readme",
	"bugs": "https://github.com/dancingteeth/obsidigram/issues",
	"devDependencies": {
		"@types/node": "^18.0.0",
		"builtin-modules": "^3.3.0",
		"esbuild": "^0.27.0",
		"obsidian": "latest",
		"tslib": "^2.4.0",
		"typescript": "^5.0.0"
	}
}
