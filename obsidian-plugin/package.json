{
	"name": "obsidigram",
	"version": "0.1.0",
	"description": "Turn Obsidian into a headless CMS for Telegram",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"telegram",
		"scheduler",
		"cms"
	],
	"author": "dancingteeth",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^18.0.0",
		"builtin-modules": "^3.3.0",
		"esbuild": "^0.17.0",
		"obsidian": "latest",
		"tslib": "^2.4.0",
		"typescript": "^5.0.0"
	}
}

