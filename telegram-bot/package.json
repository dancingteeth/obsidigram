{
	"name": "obsidigram-bot",
	"version": "0.1.0",
	"packageManager": "pnpm@9.15.0",
	"description": "Telegram bot API server for Obsidigram plugin",
	"main": "dist/index.js",
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc",
		"start": "node dist/index.js",
		"deploy": "./deploy.sh",
		"deploy:remote": "./deploy.sh",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": [
		"telegram",
		"bot",
		"grammy",
		"scheduler"
	],
	"author": "dancingteeth",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/dancingteeth/obsidigram.git"
	},
	"homepage": "https://github.com/dancingteeth/obsidigram#readme",
	"bugs": "https://github.com/dancingteeth/obsidigram/issues",
	"dependencies": {
		"cors": "^2.8.5",
		"dotenv": "^16.3.1",
		"grammy": "^1.21.0",
		"express": "^4.18.2",
		"node-cron": "^3.0.3"
	},
	"devDependencies": {
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/node": "^20.10.0",
		"@types/node-cron": "^3.0.11",
		"tsx": "^4.7.0",
		"typescript": "^5.3.3",
		"vitest": "^2.1.0"
	},
	"engines": {
		"node": ">=18.0.0"
	}
}
