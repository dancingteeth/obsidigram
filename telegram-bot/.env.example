# Obsidigram Telegram Bot - Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Required for server/development only (not for plugin users)
# ===========================================
# Bot token from @BotFather — only needed to run the bot server
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ===========================================
# Server
# ===========================================
PORT=3001
DATA_DIR=./data

# ===========================================
# Optional - Multi-platform (Facebook, Threads)
# ===========================================
# FB_PAGE_ID=
# FB_PAGE_ACCESS_TOKEN=
# THREADS_USER_ID=
# THREADS_ACCESS_TOKEN=
