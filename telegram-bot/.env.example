# Obsidigram Telegram Bot - Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Required - Telegram
# ===========================================
# Bot token from @BotFather (https://t.me/botfather)
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Channel/chat ID where posts are published
# For channels: typically -100xxxxxxxxxx
# Get it: forward a channel message to @userinfobot, or use getUpdates API
TELEGRAM_CHAT_ID=-1001234567890

# ===========================================
# Server
# ===========================================
PORT=3001
DATA_DIR=./data

# ===========================================
# Optional - Multi-platform (Facebook, Threads)
# ===========================================
# FB_PAGE_ID=
# FB_PAGE_ACCESS_TOKEN=
# THREADS_USER_ID=
# THREADS_ACCESS_TOKEN=
