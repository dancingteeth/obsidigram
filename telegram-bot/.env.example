# Obsidigram Telegram Bot - Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Required for server/development only (not for plugin users)
# ===========================================
# Bot token from @BotFather — only needed to run the bot server
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ===========================================
# Server
# ===========================================
PORT=3001
DATA_DIR=./data

# ===========================================
# Optional - Multi-platform (Facebook, Threads)
# ===========================================
# FB_PAGE_ID=
# FB_PAGE_ACCESS_TOKEN=
# THREADS_USER_ID=
# THREADS_ACCESS_TOKEN=

# When FB/Threads use the env vars above, they are server-wide (one Page / Threads account).
# By default they are HIDDEN from the Obsidian HTTP API so other users' API keys do not see
# your Page name or post to your Meta accounts. Telegram + X (BYOK from Obsidian) stay visible.
# Set to true only on a single-tenant server where every API key should use these Meta targets.
# API_EXPOSE_SERVER_META_PLATFORMS=true
